# ─── Build ───────────────────────────────────────────────────────────────────
build --incompatible_strict_action_env
build --action_env=PATH
common --repo_env=GOTOOLCHAIN=auto

# ─── Platforms (cross-compilation) ───────────────────────────────────────────
build:linux_amd64 --platforms=//platforms:linux_amd64
build:linux_arm64 --platforms=//platforms:linux_arm64
build:darwin_amd64 --platforms=//platforms:darwin_amd64
build:darwin_arm64 --platforms=//platforms:darwin_arm64

# ─── Test ────────────────────────────────────────────────────────────────────
test --test_output=errors
test --test_verbose_timeout_warnings

# ─── Performance ─────────────────────────────────────────────────────────────
common --experimental_repository_cache_hardlinks

# ─── Convenience ─────────────────────────────────────────────────────────────
common --color=yes
build --show_timestamps
