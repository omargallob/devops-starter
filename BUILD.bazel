load("@gazelle//:def.bzl", "gazelle")
load("//bazel:shellcheck.bzl", "shellcheck_test")

# gazelle:prefix github.com/omargallob/devops-starter
gazelle(name = "gazelle")

# Lint all shell scripts in the repo
shellcheck_test(
    name = "shellcheck",
    srcs = [
        "scripts/install.sh",
        "dotfiles/shared/aliases.sh",
        "dotfiles/shared/env.sh",
        "dotfiles/shared/functions.sh",
    ],
)
